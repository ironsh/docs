{
  "main": ".open-next/worker.js",
  "name": "docs",
  "account_id": "YOUR_ACCOUNT_ID",
  "compatibility_date": "2025-03-25",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
  "images": {
    "binding": "IMAGES",
  },
  "routes": [
    {
      "pattern": "docs.iron.sh",
      "custom_domain": true,
    },
  ],
}
